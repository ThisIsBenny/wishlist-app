{
  "version": "1.5.1",
  "overrides": {
    "cheerio": "1.0.0-rc.12",
    "undici": "6.14.1"
  },
  "scripts": {
    "dev": "concurrently --kill-others \"npm run dev:frontend\" \"npm run dev:backend\"",
    "demo": "npm run build && prisma migrate deploy && prisma migrate reset -f && node dist/api/server.js",
    "dev:frontend": "vite",
    "dev:backend": "nodemon -r dotenv/config ./src/api/server.ts",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "vite build",
    "build:backend": "prisma generate && tsc -p tsconfig.backend.json --outDir dist",
    "preview": "vite preview --port 5050",
    "serve": "node dist/api/server.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:unit": "vitest",
    "test:unit:ci": "vitest --run",
    "test:api": "vitest run --config vitest.config.api.mjs",
    "test": "vitest run",
    "coverage": "vitest run --environment jsdom --coverage",
    "coverage:api": "vitest run --config vitest.config.api.ts --coverage",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "prepare": "husky install",
    "preversion": "git pull --ff-only",
    "postversion": "git push --follow-tags"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/compress": "^6.5.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/static": "^6.12.0",
    "@prisma/client": "^6.5.0",
    "@tailwindcss/line-clamp": "^0.3.1",
    "@vueuse/core": "^10.11.0",
    "axios": "^1.7.9",
    "cheerio": "1.0.0-rc.12",
    "fastify": "^4.26.0",
    "open-graph-scraper": "^6.4.0",
    "vee-validate": "^4.15.0",
    "vue": "^3.5.13",
    "vue-i18n": "^10.0.5",
    "vue-router": "^4.5.0",
    "vue-toastification": "^2.0.0-rc.5",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@rushstack/eslint-patch": "^1.10.4",
    "@types/node": "^22.10.7",
    "@types/open-graph-scraper": "^4.8.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^1.5.0",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^11.0.3",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "c8": "^10.1.2",
    "concurrently": "^9.1.2",
    "dotenv": "^16.4.7",
    "eslint": "^8.57.1",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-vue": "^9.32.0",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "nodemon": "^3.1.9",
    "pino-pretty": "^13.0.0",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "prisma": "^6.5.0",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.3",
    "unplugin-vue-components": "^28.0.0",
    "vite": "^5.4.14",
    "vitest": "^1.5.0",
    "vue-tsc": "^2.2.0"
  }
}
